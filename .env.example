# SummitFit Adventures — environment variables
# Copy this file to `.env.local` and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.
#
# ⚠️  NEVER put the Supabase service_role key (or any server secret) in a VITE_ var —
#     everything below is inlined into the public JS bundle. Only anon-safe values here.

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase anon public key (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public origin used to build the OAuth redirect. Must match the dev port (8080).
VITE_SITE_URL=http://localhost:8080

# Email to promote to the 'admin' role (run the SQL UPDATE in supabase/schema.sql once).
VITE_ADMIN_EMAIL=ernest@summitfitadventures.com
